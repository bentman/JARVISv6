{
  "manifest_id": "hw-gpu-nvidia-cuda",
  "version": "0.0.1",
  "merge_behavior": "additive",
  "applies_when": {
    "gpu_available": true,
    "cuda_available": true,
    "gpu_vendor": [
      "nvidia"
    ]
  },
  "additive_requirements": {
    "install": {
      "pip_extra_index_urls": [
        "https://download.pytorch.org/whl/cu128"
      ]
    },
    "python_packages": [
      "GPUtil>=1.4",
      "nvidia-ml-py>=12.0",
      "nvidia-cublas-cu12>=12.0",
      "nvidia-cudnn-cu12>=9.0",
      "torch>=2.11.0"
    ]
  },
  "notes": "NVIDIA CUDA additive requirements: telemetry (GPUtil, nvidia-ml-py), CUDA libraries (cublas, cudnn), and torch for GPU inference and DLL/runtime evidence checks in preflight code."
}